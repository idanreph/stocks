# ── DATA FETCHER ──────────────────────────────────────────────────────────────
def fetch_financials(ticker: str) -> dict:
    """Pull raw financials from Yahoo Finance and normalize to DST inputs."""
    try:
        stock = yf.Ticker(ticker)
        bs    = stock.balance_sheet
        fi    = stock.financials
        cf    = stock.cashflow
        info  = stock.info

        def safe_get(df, *keys):
            for k in keys:
                try:
                    vals = df.loc[k]
                    v = vals.iloc[0]
                    if pd.notna(v):
                        return float(v)
                except:
                    pass
            return None

        # Core extraction — multiple key aliases for robustness
        ebitda       = safe_get(fi, 'EBITDA', 'Ebitda')
        total_debt   = safe_get(bs, 'Total Debt', 'TotalDebt', 'Long Term Debt And Capital Lease Obligation')
        interest_exp = safe_get(fi, 'Interest Expense', 'InterestExpense')
        op_income    = safe_get(fi, 'Operating Income', 'OperatingIncome')
        net_income   = safe_get(fi, 'Net Income', 'NetIncome')
        curr_assets  = safe_get(bs, 'Current Assets', 'TotalCurrentAssets')
        curr_liab    = safe_get(bs, 'Current Liabilities', 'TotalCurrentLiabilities')
        total_assets = safe_get(bs, 'Total Assets', 'TotalAssets')
        goodwill     = safe_get(bs, 'Goodwill', 'GoodwillAndIntangibleAssets') or 0
        fcf          = safe_get(cf, 'Free Cash Flow', 'FreeCashFlow')
        revenue      = safe_get(fi, 'Total Revenue', 'TotalRevenue')

        # Year-over-year debt growth
        try:
            debt_cols = bs.loc['Total Debt'] if 'Total Debt' in bs.index else bs.loc['TotalDebt']
            debt_now  = float(debt_cols.iloc[0]) if len(debt_cols) > 0 else None
            debt_prev = float(debt_cols.iloc[1]) if len(debt_cols) > 1 else None
            debt_growth = (debt_now - debt_prev) / abs(debt_prev) if debt_prev and debt_prev != 0 else None
        except:
            debt_growth = None

        # Margin trend (latest vs prior year)
        try:
            margins = fi.loc['Gross Profit'] / fi.loc['Total Revenue']
            margin_trend = float(margins.iloc[0]) - float(margins.iloc[1]) if len(margins) > 1 else None
        except:
            margin_trend = None

        # Accruals ratio (earnings quality)
        accruals_ratio = None
        if net_income and fcf and revenue:
            accruals_ratio = (net_income - fcf) / abs(revenue) if revenue != 0 else None

        market_cap = info.get('marketCap')
        price      = info.get('currentPrice') or info.get('regularMarketPrice')
        sector     = info.get('sector', 'Unknown')
        name       = info.get('shortName', ticker)

        return {
            "ticker":       ticker.upper(),
            "name":         name,
            "sector":       sector,
            "price":        price,
            "market_cap":   market_cap,
            "ebitda":       ebitda,
            "total_debt":   total_debt,
            "interest_exp": abs(interest_exp) if interest_exp else None,
            "op_income":    op_income,
            "net_income":   net_income,
            "curr_assets":  curr_assets,
            "curr_liab":    curr_liab,
            "total_assets": total_assets,
            "goodwill":     goodwill,
            "fcf":          fcf,
            "revenue":      revenue,
            "debt_growth":  debt_growth,
            "margin_trend": margin_trend,
            "accruals_ratio": accruals_ratio,
            "fetched_at":   datetime.now().isoformat(),
        }
    except Exception as e:
        return {"ticker": ticker.upper(), "error": str(e)}


# ── DST SCORE ENGINE ──────────────────────────────────────────────────────────
def calculate_dst_score(data: dict) -> dict:
    """
    Core DST equation applied to corporate financials:
    dΘ/dt = ρ − (σ − κ)
    
    Returns Θ (0-100), regime, findings, observability gap.
    """
    if "error" in data:
        return {"theta": None, "regime": "NO DATA", "error": data["error"]}

    d = data
    findings = []
    score    = 50.0  # Start at Plastic midpoint — corporates start under pressure
    sigma_score = 0
    rho_score   = 0
    kappa_score = 0

    def add(name, value, impact, category, message):
        nonlocal score, sigma_score, rho_score, kappa_score
        if value is None:
            return
        score += impact
        if category == "sigma":
            sigma_score += abs(impact) if impact < 0 else 0
        elif category == "rho":
            rho_score += impact if impact > 0 else 0
        elif category == "kappa":
            kappa_score += abs(impact) if impact < 0 else 0
        findings.append({
            "metric": name,
            "value": round(value, 4),
            "impact": round(impact, 1),
            "category": category,
            "message": message
        })

    # ── σ AMPLIFIERS ──────────────────────────────────────────────────────────

    # Leverage (Debt/EBITDA) — the killer
    if d["total_debt"] and d["ebitda"] and d["ebitda"] > 0:
        lev = d["total_debt"] / d["ebitda"]
        if lev > 8:
            impact = -25
            msg = f"Debt/EBITDA={lev:.1f}x — critical. System under terminal leverage stress."
        elif lev > 6:
            impact = -18
            msg = f"Debt/EBITDA={lev:.1f}x — late plastic. κ running out."
        elif lev > 4:
            impact = -10
            msg = f"Debt/EBITDA={lev:.1f}x — plastic. Monitoring required."
        elif lev > 2:
            impact = -4
            msg = f"Debt/EBITDA={lev:.1f}x — manageable."
        else:
            impact = +5
            msg = f"Debt/EBITDA={lev:.1f}x — elastic. Low leverage stress."
        add("leverage", lev, impact, "sigma", msg)

    # Interest burden (Interest/Operating Income) — real-time rate pain
    if d["interest_exp"] and d["op_income"] and d["op_income"] > 0:
        burden = d["interest_exp"] / d["op_income"]
        if burden > 0.6:
            impact = -22
            msg = f"Interest/OpIncome={burden:.0%} — >60% of earnings burn on interest. Residual."
        elif burden > 0.4:
            impact = -15
            msg = f"Interest/OpIncome={burden:.0%} — rate environment is crushing this structure."
        elif burden > 0.25:
            impact = -8
            msg = f"Interest/OpIncome={burden:.0%} — elevated. Financing pain rising."
        else:
            impact = +3
            msg = f"Interest/OpIncome={burden:.0%} — contained. Low financing stress."
        add("interest_burden", burden, impact, "sigma", msg)

    # Debt growth YoY — acceleration of structural loading
    if d["debt_growth"] is not None:
        dg = d["debt_growth"]
        if dg > 0.3:
            add("debt_growth", dg, -14, "sigma",
                f"Debt grew {dg:.0%} YoY — σ accumulating faster than capacity.")
        elif dg > 0.15:
            add("debt_growth", dg, -7, "sigma",
                f"Debt grew {dg:.0%} YoY — loading increasing.")
        elif dg < -0.1:
            add("debt_growth", dg, +6, "rho",
                f"Debt reduced {abs(dg):.0%} YoY — genuine ρ. Capacity rebuilding.")
        else:
            add("debt_growth", dg, -2, "sigma",
                f"Debt flat YoY — σ stable.")

    # ── κ MASKING PATTERNS ────────────────────────────────────────────────────

    # Goodwill ratio — hidden fragility on balance sheet
    if d["goodwill"] and d["total_assets"]:
        gr = d["goodwill"] / d["total_assets"]
        if gr > 0.45:
            add("goodwill_ratio", gr, -12, "kappa",
                f"Goodwill={gr:.0%} of assets — κ_a. Write-down risk masks real book value.")
        elif gr > 0.25:
            add("goodwill_ratio", gr, -6, "kappa",
                f"Goodwill={gr:.0%} of assets — elevated. Watch acquisition integration.")
        else:
            add("goodwill_ratio", gr, 0, "kappa",
                f"Goodwill={gr:.0%} of assets — within normal range.")

    # Earnings quality (accruals) — is income real or paper?
    if d["accruals_ratio"] is not None:
        ar = d["accruals_ratio"]
        if ar > 0.08:
            add("accruals_ratio", ar, -12, "kappa",
                f"Accruals ratio={ar:.2%} — earnings quality low. κ: reported income masked by accruals.")
        elif ar > 0.03:
            add("accruals_ratio", ar, -5, "kappa",
                f"Accruals ratio={ar:.2%} — moderate. FCF vs net income diverging.")
        else:
            add("accruals_ratio", ar, +4, "rho",
                f"Accruals ratio={ar:.2%} — high earnings quality. ρ signal.")

    # FCF vs Net Income — the realest κ detector
    if d["fcf"] and d["net_income"] and d["net_income"] != 0:
        ratio = d["fcf"] / abs(d["net_income"])
        if ratio < 0.5:
            add("fcf_vs_net", ratio, -10, "kappa",
                f"FCF/NetIncome={ratio:.1f}x — earnings not converting to cash. Classic κ_a.")
        elif ratio > 1.2:
            add("fcf_vs_net", ratio, +8, "rho",
                f"FCF/NetIncome={ratio:.1f}x — cash generation exceeds reported earnings. ρ signal.")
        else:
            add("fcf_vs_net", ratio, 0, "kappa",
                f"FCF/NetIncome={ratio:.1f}x — in-line.")

    # ── ρ HEALING SIGNALS ─────────────────────────────────────────────────────

    # Current ratio — liquidity oxygen
    if d["curr_assets"] and d["curr_liab"] and d["curr_liab"] > 0:
        cr = d["curr_assets"] / d["curr_liab"]
        if cr > 2.5:
            add("current_ratio", cr, +15, "rho",
                f"Current ratio={cr:.2f} — strong liquidity buffer. Elastic zone.")
        elif cr > 1.5:
            add("current_ratio", cr, +8, "rho",
                f"Current ratio={cr:.2f} — healthy. Room to absorb near-term stress.")
        elif cr > 1.0:
            add("current_ratio", cr, +2, "rho",
                f"Current ratio={cr:.2f} — adequate. Minimal buffer.")
        else:
            add("current_ratio", cr, -15, "sigma",
                f"Current ratio={cr:.2f} — BELOW 1.0. Liquidity suffocation. Residual signal.")

    # FCF yield — real capital generation
    if d["fcf"] and d["market_cap"] and d["market_cap"] > 0:
        fcfy = d["fcf"] / d["market_cap"]
        if fcfy > 0.08:
            add("fcf_yield", fcfy, +14, "rho",
                f"FCF yield={fcfy:.1%} — high. Company generates real structural capital.")
        elif fcfy > 0.04:
            add("fcf_yield", fcfy, +7, "rho",
                f"FCF yield={fcfy:.1%} — positive. Cash generation healthy.")
        elif fcfy > 0:
            add("fcf_yield", fcfy, +2, "rho",
                f"FCF yield={fcfy:.1%} — minimal positive FCF.")
        else:
            add("fcf_yield", fcfy, -8, "sigma",
                f"FCF yield={fcfy:.1%} — NEGATIVE. Burning cash. σ amplifier.")

    # Margin trend — structural improvement or decay?
    if d["margin_trend"] is not None:
        mt = d["margin_trend"]
        if mt > 0.03:
            add("margin_trend", mt, +12, "rho",
                f"Gross margin improved {mt:.1%} YoY — structural healing (ρ).")
        elif mt > 0:
            add("margin_trend", mt, +4, "rho",
                f"Gross margin up {mt:.1%} — marginal improvement.")
        elif mt > -0.02:
            add("margin_trend", mt, -3, "kappa",
                f"Gross margin down {abs(mt):.1%} — κ_a pressure building.")
        else:
            add("margin_trend", mt, -10, "sigma",
                f"Gross margin collapsed {abs(mt):.1%} — σ amplifying through margins.")

    # ── SCORE CLAMPING + REGIME ───────────────────────────────────────────────
    theta = max(0, min(100, round(score)))

    if theta >= 75:
        regime = "Elastic"
        regime_desc = "Genuinely healthy. Structure absorbs stress."
        regime_emoji = "🟢"
    elif theta >= 50:
        regime = "Plastic"
        regime_desc = "Functioning via masking. Capacity declining."
        regime_emoji = "🟡"
    elif theta >= 25:
        regime = "Late Plastic"
        regime_desc = "κ near saturation. Each shock costs more."
        regime_emoji = "🟠"
    else:
        regime = "Residual"
        regime_desc = "Delayed failure embedded. κ exhausted."
        regime_emoji = "🔴"

    # ── OBSERVABILITY GAP ─────────────────────────────────────────────────────
    # Apparent health = what naive P/E-based analysis sees
    # (market cap relative to earnings, ignoring structural stress)
    apparent = min(100, max(0, round(50 + rho_score - (sigma_score * 0.2))))
    obs_gap  = max(0, apparent - theta)
    obs_severity = "critical" if obs_gap >= 30 else "high" if obs_gap >= 20 else "medium" if obs_gap >= 10 else "low"

    # ── σ_eff ─────────────────────────────────────────────────────────────────
    sigma_eff_note = (
        "contained — ρ absorbing load" if theta >= 75 else
        "partially masked — κ active" if theta >= 50 else
        "elevated — κ near exhaustion" if theta >= 25 else
        "critical — σ dominant"
    )

    # Annual cost estimate (heuristic)
    annual_cost = None
    if d["interest_exp"] and d["ebitda"]:
        burden_pct = d["interest_exp"] / d["ebitda"] if d["ebitda"] > 0 else 0
        if burden_pct > 0.3:
            annual_cost = f"${d['interest_exp']/1e9:.1f}B interest annually"

    return {
        "ticker":       data["ticker"],
        "name":         data.get("name", data["ticker"]),
        "sector":       data.get("sector", "Unknown"),
        "price":        data.get("price"),
        "market_cap":   data.get("market_cap"),
        "theta":        theta,
        "regime":       regime,
        "regime_desc":  regime_desc,
        "regime_emoji": regime_emoji,
        "apparent":     apparent,
        "obs_gap":      obs_gap,
        "obs_severity": obs_severity,
        "sigma_score":  round(sigma_score, 1),
        "rho_score":    round(rho_score, 1),
        "kappa_score":  round(kappa_score, 1),
        "sigma_eff_note": sigma_eff_note,
        "annual_cost":  annual_cost,
        "findings":     findings,
        "scanned_at":   datetime.now().isoformat(),
    }


