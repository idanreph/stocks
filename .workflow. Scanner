def save_watchlist(tickers: list):
    with open(WATCHLIST_FILE, "w") as f:
        json.dump(tickers, f, indent=2)
    print(f"Watchlist saved: {len(tickers)} tickers")


# ── HISTORY / TREND ───────────────────────────────────────────────────────────
def update_history(results: list):
    history = {}
    if os.path.exists(HISTORY_FILE):
        with open(HISTORY_FILE) as f:
            history = json.load(f)
    ts = datetime.now().isoformat()
    for r in results:
        if r.get("theta") is None:
            continue
        ticker = r["ticker"]
        if ticker not in history:
            history[ticker] = []
        history[ticker].append({"ts": ts, "theta": r["theta"], "regime": r["regime"]})
        history[ticker] = history[ticker][-20:]  # keep last 20
    with open(HISTORY_FILE, "w") as f:
        json.dump(history, f, indent=2)

def get_trajectory(ticker: str) -> str:
    """dΘ/dt — is capacity improving or declining?"""
    if not os.path.exists(HISTORY_FILE):
        return "first scan"
    with open(HISTORY_FILE) as f:
        history = json.load(f)
    if ticker not in history or len(history[ticker]) < 2:
        return "first scan"
    recent = history[ticker][-3:]
    thetas = [e["theta"] for e in recent]
    avg_delta = (thetas[-1] - thetas[0]) / (len(thetas) - 1)
    if avg_delta > 1:   return f"↑ +{avg_delta:.1f} pts/scan (improving)"
    if avg_delta < -1:  return f"↓ {avg_delta:.1f} pts/scan (declining)"
    return "→ stable"


# ── CONSOLE OUTPUT ────────────────────────────────────────────────────────────
def print_result(r: dict):
    if r.get("theta") is None:
        print(f"  {r['ticker']:6s} ❌ {r.get('error','no data')[:60]}")
        return

    bar = "█" * (r["theta"] // 10) + "░" * (10 - r["theta"] // 10)
    mc = f"${r['market_cap']/1e9:.1f}B" if r.get("market_cap") else "—"
    traj = get_trajectory(r["ticker"])

    print(f"\n  {r['regime_emoji']} {r['ticker']:6s}  {r['name'][:30]}")
    print(f"     Θ = {r['theta']:3d}/100  [{bar}]  {r['regime']}")
    print(f"     Apparent: {r['apparent']}/100  │  Gap: {r['obs_gap']} pts [{r['obs_severity']}]")
    print(f"     σ: {r['sigma_score']:.0f}  ρ: {r['rho_score']:.0f}  κ: {r['kappa_score']:.0f}  │  {r['sigma_eff_note']}")
    print(f"     dΘ/dt: {traj}  │  MktCap: {mc}")
    print(f"     ─ {r['regime_desc']}")

    # Top 3 findings
    top = sorted(r["findings"], key=lambda x: x["impact"])[:3]
    for f in top:
        cat = {"sigma":"σ","kappa":"κ","rho":"ρ"}.get(f["category"],"?")
        sign = "+" if f["impact"] > 0 else ""
        print(f"       {cat} [{sign}{f['impact']:+.0f}] {f['message'][:70]}")

    if r.get("annual_cost"):
        print(f"       💰 {r['annual_cost']}")


# ── EXPORT ────────────────────────────────────────────────────────────────────
def export_csv(results: list):
    rows = []
    for r in results:
        if r.get("theta") is None:
            continue
        rows.append({
            "ticker":      r["ticker"],
            "name":        r["name"],
            "sector":      r["sector"],
            "theta":       r["theta"],
            "regime":      r["regime"],
            "apparent":    r["apparent"],
            "obs_gap":     r["obs_gap"],
            "sigma":       r["sigma_score"],
            "rho":         r["rho_score"],
            "kappa":       r["kappa_score"],
            "price":       r.get("price"),
            "market_cap":  r.get("market_cap"),
            "scanned_at":  r["scanned_at"],
        })
    df = pd.DataFrame(rows).sort_values("theta")
    df.to_csv(RESULTS_FILE, index=False)
    print(f"\n  Results saved → {RESULTS_FILE}")
    return df


# ── MAIN ──────────────────────────────────────────────────────────────────────
def run_scan(tickers=None, verbose=True):
    if tickers is None:
        tickers = load_watchlist()

    print("\n══════════════════════════════════════════════════════")
    print("  DST FINANCIAL SCANNER v1.0")
    print("  dΘ/dt = ρ − (σ − κ)  ·  ρ heals · κ hides · σ kills")
    print("  SSRN 6434119 · Idan Rephiah · 2026")
    print("══════════════════════════════════════════════════════\n")

    results = []
    for ticker in tickers:
        if verbose:
            print(f"  Scanning {ticker}...", end="\r")
        data   = fetch_financials(ticker)
        result = calculate_dst_score(data)
        results.append(result)
        if verbose:
            print_result(result)

    # Summary table
    valid = [r for r in results if r.get("theta") is not None]
    valid.sort(key=lambda x: x["theta"])

    print("\n\n══════════════════════════════════════════════════════")
    print("  DST RANKING — WORST TO BEST")
    print("══════════════════════════════════════════════════════")
    print(f"  {'Ticker':<8} {'Θ':>5}  {'Regime':<14} {'Gap':>5}  Name")
    print("  " + "─" * 60)
    for r in valid:
        mc = f"${r['market_cap']/1e9:.0f}B" if r.get("market_cap") else "  —  "
        print(f"  {r['regime_emoji']}{r['ticker']:<7} {r['theta']:>4}  {r['regime']:<14} {r['obs_gap']:>4}  {r['name'][:28]}")

    # Regime distribution
    regimes = {}
    for r in valid:
        regimes[r["regime"]] = regimes.get(r["regime"], 0) + 1
    print(f"\n  Regimes: ", end="")
    for reg, count in regimes.items():
        print(f"{reg}: {count}  ", end="")
    print()

    # Save
    update_history(results)
    df = export_csv(results)

    print("\n  ρ heals · κ hides · σ kills")
    print("══════════════════════════════════════════════════════\n")

    return results, df


